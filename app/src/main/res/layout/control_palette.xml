<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp"
    android:gravity="center_vertical">

    <ImageButton
        android:id="@+id/palettePrev"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_arrow_left"
        android:background="@null"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="Previous palette" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/paletteSwatchRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/paletteName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/press_start_2p"
            android:textSize="10sp"
            android:textColor="@color/mwhite"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/paletteNext"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_arrow_right"
        android:background="@null"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="Next palette" />
</LinearLayout>
